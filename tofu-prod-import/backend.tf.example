# Remote-state adoption (docs/remote-state.md). To adopt:
#   cp backend.tf.example backend.tf      # backend.tf is gitignored
#   make init MODULE=tofu-prod-import     # from the repo root
# Bucket/key/region are injected by `make init` — discovered from the account
# via SSM /rds/tofu/state-bucket, never hardcoded. Lockfile needs tofu >= 1.10.
# NOTE: read-only operators need s3 read on the state bucket and should plan
# with -lock=false (locking writes a lockfile object).
terraform {
  backend "s3" {
    use_lockfile = true
  }
}
