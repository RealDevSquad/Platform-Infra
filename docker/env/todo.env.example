# Local-dev defaults for todo-backend (safe to keep; real prod values live in GitHub Environments)
SECRET_KEY=local-secret-key
ENV=staging
ALLOWED_HOSTS=localhost,127.0.0.1,todo-backend
MONGODB_URI=mongodb://todo-mongo:27017/?replicaSet=rs0
DB_NAME=todo-app
GOOGLE_OAUTH_CLIENT_ID=local-client-id
GOOGLE_OAUTH_CLIENT_SECRET=local-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost/todo/v1/auth/google/callback
PUBLIC_KEY=local-test-public-key
PRIVATE_KEY=local-test-private-key
ACCESS_LIFETIME=3600
REFRESH_LIFETIME=604800
ACCESS_TOKEN_COOKIE_NAME=local-todo-access
REFRESH_TOKEN_COOKIE_NAME=local-todo-refresh
COOKIE_DOMAIN=localhost
COOKIE_SECURE=False
COOKIE_HTTPONLY=True
COOKIE_SAMESITE=Lax
TODO_BACKEND_BASE_URL=http://localhost/todo
TODO_UI_BASE_URL=http://localhost:3000
TODO_UI_REDIRECT_PATH=dashboard
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
SWAGGER_UI_PATH=/todo/api/schema
ADMIN_EMAILS=admin@example.com
FRONTEND_URL=http://localhost:3000
POSTGRES_HOST=todo-postgres
POSTGRES_PORT=5432
POSTGRES_DB=todo-app
POSTGRES_USER=local-user
POSTGRES_PASSWORD=local-password
DUAL_WRITE_ENABLED=True
DUAL_WRITE_SYNC_MODE=async
DUAL_WRITE_RETRY_ATTEMPTS=3
DUAL_WRITE_RETRY_DELAY=5
