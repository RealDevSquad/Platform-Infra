# Local-dev defaults for tiny-site-backend (Go/Gin)
ENV=staging
GIN_MODE=debug
JWT_SECRET=local-secret
JWT_VALIDITY_IN_HOURS=24
JWT_ISSUER=tiny-backend-local
PORT=3010
DOMAIN=localhost
AUTH_REDIRECT_URL=http://localhost:3000/
DB_URL=postgresql://postgres:local-password@tinysite-postgres:5432/tinysite?sslmode=disable
DB_HOST=tinysite-postgres
DB_PORT=5432
DB_MAX_OPEN_CONNECTIONS=10
GOOGLE_CLIENT_ID=local-client-id
GOOGLE_CLIENT_SECRET=local-client-secret
GOOGLE_REDIRECT_URL=http://localhost/tiny/v1/auth/google/callback
ALLOWED_ORIGINS=http://localhost:3000
TOKEN_VALIDITY_IN_SECONDS=86400
USER_MAX_URL_COUNT=50
WEB_APP_BASE_URL=http://localhost:3000
