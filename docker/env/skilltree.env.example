# Local-dev defaults for skill-tree-backend (Spring Boot)
# Must be a REAL parseable RSA public key (throwaway is fine): bare base64 X.509/SPKI DER as below,
# or full PEM — the app strips BEGIN/END headers and whitespace, then base64-decodes (JWTUtils @PostConstruct).
# A placeholder string crashes boot. Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 \
#   -out key.pem && openssl rsa -in key.pem -pubout -outform DER | base64 | tr -d '\n'
RDS_PUBLIC_
MYSQL_HOST=skilltree-mysql
MYSQL_PORT=3306
DB_NAME=skilltree
MYSQL_DB_USERNAME=root
MYSQL_DB_PASSWORD=local-password
RDS_BACKEND_BASE_URL=http://localhost/api
SKILL_TREE_BACKEND_BASE_URL=http://localhost/skilltree
SKILL_TREE_FRONTEND_BASE_URL=http://localhost:3001
SPRING_PROFILES_ACTIVE=staging
API_V1_PREFIX=/api/v1
