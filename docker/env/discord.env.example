# Local-dev defaults for discord-service + discord-message-broker.
# NOTE: discord-service :latest (builds since Feb 2025) opens a real Discord
# gateway session at boot (commands/register); a dummy BOT_TOKEN makes it panic
# ("websocket: close 4004: Authentication failed") and crash-loop. No env var
# skips it — either set a real staging BOT_TOKEN, or pin DISCORD_TAG in ../.env
# to a pre-register build (e.g. 9739d3fb9ca46a2137f0b913f03074a2818b87b9,
# 2025-01-26) which serves /health + /queue and connects to RabbitMQ without
# Discord login. The broker needs no Discord creds at all.
ENV=staging
PORT=3050
QUEUE_NAME=DISCORD_QUEUE
QUEUE_URL=amqp://rabbitmq:5672
RDS_BASE_API_URL=https://staging-api.realdevsquad.com
MAIN_SITE_URL=http://localhost
DISCORD_PUBLIC_KEY=local-public-key
BOT_TOKEN=local-bot-token
GUILD_ID=0
BOT_PRIVATE_KEY=local-private-key
DISCORD_SERVICE_URL=http://discord-service:3050
